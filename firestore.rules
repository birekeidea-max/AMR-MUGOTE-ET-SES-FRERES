rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'birekeidea@gmail.com'
      ); 
    }

    // Reservations
    match /reservations/{resId} {
      allow read, list, create, update: if true;
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read, write: if true;
    }

    // Users List for Admins
    match /users_list/{userId} {
      allow read, write: if true;
    }

    // News (Public Read)
    match /news/{newsId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if true;

      // Comments Subcollection
      match /comments/{commentId} {
        allow read, write: if true;
      }
    }

    // Admin lookup
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == 'birekeidea@gmail.com' && adminId == request.auth.uid;
    }

    // Site Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fleet (Public Read, Admin Write)
    match /fleet/{boatId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Support Conversations & Chat messages
    match /conversations/{convId} {
      allow read, list, create, update: if true;

      // Messages Subcollection
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }

    // Schedules (Public Read, Admin Write)
    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
