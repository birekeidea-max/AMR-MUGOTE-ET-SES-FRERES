rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'birekeidea@gmail.com'
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Reservations
    match /reservations/{resId} {
      function isValidReservation(data) {
        return data.fullName is string && data.fullName.size() > 0 &&
               data.lastName is string && data.lastName.size() > 0 &&
               data.phone is string && data.phone.size() > 0 &&
               data.itinerary in ['Bukavu-Goma', 'Goma-Bukavu'] &&
               data.ship in ['Mugote 1', 'Mugote 2', 'Mugote 3'] &&
               data.travelClass in ['1ère Classe', '2ème Classe', '3ème Classe', 'VIP'] &&
               data.passengersCount is number && data.passengersCount > 0 &&
               data.status in ['PENDING', 'VALIDATED', 'REJECTED'] &&
               data.userId is string && data.userId.size() > 0;
      }

      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidReservation(incoming()) && 
                    incoming().status == 'PENDING' &&
                    incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && isValidReservation(incoming()) && (
        // Action: Owner setting transaction ID
        (isOwner(existing().userId) && 
         existing().status == 'PENDING' && 
         incoming().userId == existing().userId &&
         incoming().diff(existing()).affectedKeys().hasOnly(['transactionId', 'status']) &&
         incoming().status == 'PENDING') 
        || 
        // Action: Admin validating
        (isAdmin() && 
         incoming().userId == existing().userId &&
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'validatedAt', 'validatedBy', 'ticketId']))
      );
      
      allow delete: if isAdmin();
    }

    // Users (Split collection strategy)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && (!incoming().keys().hasAny(['role']));
    }

    // News (Public Read)
    match /news/{newsId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Public can only increment views
        incoming().diff(existing()).affectedKeys().hasOnly(['views']) &&
        incoming().views == existing().views + 1
      );

      // Comments Subcollection
      match /comments/{commentId} {
        function isValidComment(data) {
          return data.userId is string && data.userId.size() > 0 &&
                 data.text is string && data.text.size() > 0 &&
                 data.text.size() < 1000;
        }
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(incoming()) && incoming().userId == request.auth.uid;
        allow delete: if isAdmin() || isOwner(existing().userId);
      }
    }

    // Admin lookup
    match /admins/{adminId} {
      allow read: if isSignedIn();
      // Permission spéciale pour permettre l'auto-promotion initiale de l'administrateur
      allow write: if isSignedIn() && request.auth.token.email == 'birekeidea@gmail.com' && adminId == request.auth.uid;
    }
    // Site Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fleet (Public Read, Admin Write)
    match /fleet/{boatId} {
      function isValidBoat(data) {
        return data.name is string && data.name.size() > 0 &&
               data.capacity is number && data.capacity >= 0;
      }
      allow read: if true;
      allow write: if isAdmin() && isValidBoat(incoming());
    }

    // Support Conversations
    match /conversations/{convId} {
      function isValidConversation(data) {
        return data.userId is string && data.userId.size() > 0 &&
               data.userEmail is string && data.userEmail.size() > 0 &&
               data.status in ['OPEN', 'CLOSED'];
      }

      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidConversation(incoming()) && 
                    incoming().userId == request.auth.uid &&
                    incoming().status == 'OPEN';
      
      allow update: if isSignedIn() && (
        // User adding a message (lastMessage info)
        (isOwner(existing().userId) && 
         incoming().userId == existing().userId &&
         incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt', 'adminUnreadCount']))
        ||
        // Admin responding or closing
        (isAdmin() && 
         incoming().userId == existing().userId &&
         incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt', 'status', 'adminUnreadCount']))
      );

      // Messages Subcollection
      match /messages/{msgId} {
        function isValidMessage(data) {
          return data.text is string && data.text.size() > 0 &&
                 data.senderRole in ['USER', 'ADMIN', 'AI'];
        }

        allow read: if isSignedIn() && (get(/databases/$(database)/documents/conversations/$(convId)).data.userId == request.auth.uid || isAdmin());
        
        allow create: if isSignedIn() && 
                      isValidMessage(incoming()) && 
                      (
                        (incoming().senderRole == 'USER' && incoming().senderId == request.auth.uid) ||
                        (incoming().senderRole == 'AI') || // AI responses are triggered by client session
                        (incoming().senderRole == 'ADMIN' && isAdmin())
                      );
      }
    }
    match /users_list/{userId} {
      allow read: if isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
